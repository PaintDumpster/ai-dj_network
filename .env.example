# Copy this file to .env and fill in your values before running docker compose
# cp .env.example .env

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model to use for the LLM node (haiku = fast & cheap, sonnet = smarter)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ROS2 domain ID — keep at 0 unless running multiple ROS2 systems on the same network
ROS_DOMAIN_ID=0
